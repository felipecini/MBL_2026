beh_time_S = (0:(1/17.50):((19923-1)*(1/17.5))) + 53877/500 -12;



figure
offset = 0;
for i = 1:size(datadFF.goodCells,1);
    plot(datadFF.dFF(i, :) + offset);
    hold on
    offset = offset + 6;
end

plot(behSpeed.speed_cm_s - 10)



%% --------- INPUTS you already have ----------
t_ca   = datadFF.time(:);          % calcium time
dFF    = datadFF.dFF;              % C x T
t_beh1 = behSpeed.behTime_s(:);    % behavior time (option A)
t_beh2 = [] %beh_time_S%;                       % behavior time (option B: if you prefer beh_time_S, put it here)

% Choose the time you want to use for behavior (must match speed vector):
if ~isempty(t_beh2)
    t_b = t_beh2(:);
else
    t_b = t_beh1(:);
end
v_b = behSpeed.speed_cm_s(:);

% Force t_b and v_b to same length (prevents plot length mismatch)
N = min(numel(t_b), numel(v_b));
t_b = t_b(1:N);
v_b = v_b(1:N);

%% --------- 1) Ensure calcium time and dFF have same length ----------
[nCells, nTimePts] = size(dFF);
if numel(t_ca) ~= nTimePts
    M = min(numel(t_ca), nTimePts);
    t_ca = t_ca(1:M);
    dFF  = dFF(:, 1:M);
end

%% --------- 2) Trim to overlap window (so interpolation is in-range) ----------
t_min = max(min(t_ca), min(t_b));
t_max = min(max(t_ca), max(t_b));
if ~(t_min < t_max)
    error('No temporal overlap between calcium and behavior time ranges.');
end

keep = (t_ca >= t_min) & (t_ca <= t_max);
t_ca_trimmed = t_ca(keep);
dFF_trimmed  = dFF(:, keep);

%% --------- 3) Interpolate speed onto calcium timebase ----------
speed_interp = interp1(t_b, v_b, t_ca_trimmed, 'linear');
% Clean edges (no extrapolation): fill NaNs near the ends if any
speed_interp = fillmissing(speed_interp, 'nearest');

%% --------- 4) Detect bouts from behavior (sleep/low/high) ----------
bout = detect_bouts_simple(t_b, v_b, ...
    'MaxGapSec', 1, 'MinDurSec', 1.1, 'PeakMinHigh', 2.5);

%% --------- 5) PLOT: calcium (stacked) + speed line + shaded bouts ----------
figure; set(gcf,'Renderer','opengl'); hold on

% Calcium
offset = 0;
for i = 1:size(dFF_trimmed, 1)
    plot(t_ca_trimmed, dFF_trimmed(i,:) + offset, 'Color', [0 0 0 0.55], 'LineWidth', 0.9);
    offset = offset + 6;
end

% Speed (aligned to calcium timebase, shifted down for visibility)
plot(t_ca_trimmed, speed_interp - 10, 'g', 'LineWidth', 1.2);

xlabel('Time (s)'); ylabel('dF/F (offset) and speed'); 
title('Calcium traces (black) + speed (green) - shades: sleep (purple) /low movement and grooming (orange)/locomotion (blue)');
box off

% Shade bouts (on calcium axes). If clocks differ by constant dt, add it here.
ax = gca;
col_sleep = [0.45 0.10 0.65];  % purple
col_low   = [0.95 0.60 0.10];  % orange
col_high  = [0.10 0.40 0.90];  % blue
alphaVal  = 0.18;               % adjust to taste (0.35–0.9)

% If you need a constant shift (e.g., behavior is +2.3 s): set dt and add to bouts
dt = 0; % e.g., dt = -2.3;
shade_bouts_on_axes(ax, bout.sleep + dt, col_sleep, alphaVal);
shade_bouts_on_axes(ax, bout.low   + dt, col_low,   alphaVal);
shade_bouts_on_axes(ax, bout.high  + dt, col_high,  alphaVal);

xlim([t_min, t_max]);  % common window
%%
%% --------- Calcium traces + speed + hypnogram-style state bar ----------

